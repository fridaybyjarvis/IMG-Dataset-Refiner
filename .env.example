# Copy this file to ".env" to provide API keys without entering them
# in the UI.  The ".env" file is gitignored and never committed.
#
# Leave keys commented/empty to use the local backends (Ollama / LM Studio)
# which do not require authentication.

# OpenAI-compatible backends (OpenAI, OpenRouter, Groq, etc.)
# OPENAI_API_KEY=

# Anthropic Claude
# ANTHROPIC_API_KEY=

# Google Gemini
# GEMINI_API_KEY=